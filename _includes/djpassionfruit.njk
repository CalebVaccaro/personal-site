---
layout: layout.njk
---
{% block content %}
<section class="dj-hero shell" aria-labelledby="dj-hero-title">
  <div class="dj-hero-inner">
    <!-- Left column: vinyl / cover + label -->
    <div class="dj-vinyl" role="group" aria-label="Album cover and title">
      {% if imagePath %}
        <img src="{{ imagePath }}" alt="{{ title }} cover" class="vinyl-image">
      {% else %}
        <div class="vinyl-placeholder" aria-hidden="true"></div>
      {% endif %}
      <div class="vinyl-label">
        <h1 id="dj-hero-title">DJ PF (DJ PASSION FRUIT)</h1>
        <p class="dj-sub">DJ / Producer</p>
      </div>
    </div>

    <!-- Right column: intro, CTAs, main embed, booking -->
    <div class="dj-copy" role="region" aria-labelledby="dj-hero-title">
      <p class="lead">Born in Buffalo, based in Brooklyn — merging piano house, dub-dance, classic house and deep alternative grooves into sets that move both the room and the mind.</p>

      <div class="dj-ctas" aria-hidden="false">
        <a class="dj-button" href="{{ page.soundcloud or soundcloud }}" target="_blank" rel="noopener">SoundCloud</a>
        <a class="dj-button" href="{{ page.bandcamp or bandcamp }}" target="_blank" rel="noopener">Bandcamp</a>
        <a class="dj-button" href="{{ page.instagram or instagram }}" target="_blank" rel="noopener">Instagram</a>
      </div>

      <div class="dj-embed" aria-label="Main SoundCloud player">
        <iframe
          src="https://w.soundcloud.com/player/?url={{ page.soundcloud or soundcloud | urlencode }}&color=%23ff5500&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false"
          width="100%" height="140" scrolling="no" frameborder="no" allow="autoplay"></iframe>
      </div>

      <p class="muted" style="margin-top:12px;">For bookings & collabs: <a href="mailto:djpassionfruit@gmail.com">djpassionfruit@gmail.com</a></p>
    </div>
  </div>
</section>

<ul>
<iframe style="border: 0; width: 350px; height: 442px;" src="https://bandcamp.com/EmbeddedPlayer/track=108995781/size=large/bgcol=333333/linkcol=0f91ff/tracklist=false/transparent=true/" seamless><a href="https://djpf.bandcamp.com/track/i-cant-do-extended">I Can&#39;t Do (Extended) by DJ PF</a></iframe>
<iframe style="border: 0; width: 350px; height: 442px;" src="https://bandcamp.com/EmbeddedPlayer/track=3754735462/size=large/bgcol=333333/linkcol=0f91ff/tracklist=false/transparent=true/" seamless><a href="https://djpf.bandcamp.com/track/teleport">Teleport by DJ PF</a></iframe>
<iframe style="border: 0; width: 350px; height: 442px;" src="https://bandcamp.com/EmbeddedPlayer/track=739765566/size=large/bgcol=333333/linkcol=0f91ff/tracklist=false/transparent=true/" seamless><a href="https://djpf.bandcamp.com/track/dance-battle-for-life">Dance Battle For Life by DJ PF</a></iframe>

<div class="player">
<iframe
width="100%"
height="450"
scrolling="no"
frameborder="no"
allow="autoplay"
src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/djpassionfruit/sets/live-sets&color=%23ff5500&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true&visual=true">
</iframe>
</div>
{% endblock %}
